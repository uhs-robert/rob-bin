#!/usr/bin/env ruby
# frozen_string_literal: true

# ~/.local/bin/arch-news-check
require 'rss'
require 'net/http'
require 'uri'
require 'fileutils'
require 'time'

NEWS_RSS = 'https://archlinux.org/feeds/news/'
STATE_DIR = File.join(Dir.home, '.local', 'state', 'arch-news-check')
SEEN_FILE = File.join(STATE_DIR, 'seen')
YOLO = ARGV.include?('--yolo')

FileUtils.mkdir_p(STATE_DIR)

def item_id(item)
  item.guid&.content || item.link
end

def read_seen
  File.exist?(SEEN_FILE) ? File.read(SEEN_FILE).strip : nil
end

def write_seen(id)
  File.write(SEEN_FILE, "#{id}\n")
end

def open_url(url)
  system('xdg-open', url, out: File::NULL, err: File::NULL) == true
end

def decline_or_yolo(preamble = nil)
  warn preamble if preamble
  if YOLO
    warn "\nYOLO! Skipping the news, what's the worst that could happen? (Famous last words) 🤞"
    exit 0
  end
  warn "\nUpgrade aborted. Till you can find the time to read..."
  exit 1
end

begin
  uri = URI.parse(NEWS_RSS)
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.open_timeout = 5
  http.read_timeout = 5
  response = http.get(uri.request_uri)
  raise "HTTP #{response.code} #{response.message}" unless response.is_a?(Net::HTTPSuccess)

  rss = RSS::Parser.parse(response.body, false)
rescue StandardError => e
  warn "Failed to fetch Arch News: #{e.message}"
  warn "Check manually: #{NEWS_RSS}"
  exit 0
end

items = rss.items
seen = read_seen

unread =
  if seen.nil? || seen.empty?
    items
  else
    items.take_while { |item| item_id(item) != seen }
  end

if unread.empty?
  puts 'Arch News: 0 unread (no news is good news)'
  exit 0
end

puts
dates = unread.filter_map(&:pubDate).filter_map do |d|
  d.is_a?(Time) ? d : Time.parse(d.to_s)
rescue ArgumentError
  nil
end
date_range =
  if dates.length >= 2
    " #{dates.min.strftime('%Y-%m-%d')} – #{dates.max.strftime('%Y-%m-%d')}"
  elsif dates.length == 1
    " #{dates.first.strftime('%Y-%m-%d')}"
  else
    ''
  end

puts "Unread Arch News (#{unread.length} item#{unread.length == 1 ? '' : 's'}#{date_range}):"
puts

display =
  if unread.length <= 5
    unread.each_with_index.map { |item, i| [i + 1, item] }
  else
    top4 = unread[0..3].each_with_index.map { |item, i| [i + 1, item] }
    oldest = [[unread.length, unread.last]]
    top4 + [nil] + oldest
  end

display.each do |entry|
  if entry.nil?
    puts "   ... (#{unread.length - 5} more) ..."
    puts
    next
  end
  index, item = entry
  puts "#{index}. #{item.title}"
  puts "   #{item.pubDate || 'unknown date'}"
  puts "   #{item.link}"
  puts
end

answer = begin
  tty = File.open('/dev/tty', 'r+')
  tty.print 'Open unread news now? [y/N/m=mark all read] '
  tty.gets&.strip&.downcase
ensure
  tty&.close
end

decline_or_yolo('No input received.') if answer.nil?

if %w[m mark].include?(answer)
  write_seen(item_id(unread.first))
  puts "\nMarked all read. Mhm, totally read all of that."
  exit 0
end

decline_or_yolo unless %w[y yes].include?(answer)

url = unread.length == 1 ? unread.first.link : 'https://archlinux.org/news/'
failed = open_url(url) ? [] : [url]

if failed.any?
  warn "Failed to open #{failed.length} Arch News item(s)."
  exit 1
end

write_seen(item_id(unread.first))

exit 0
