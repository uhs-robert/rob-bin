#!/usr/bin/env ruby
# frozen_string_literal: true

require 'open3'

NEWS_URL = 'https://archlinux.org/news/'
YOLO = ARGV.include?('--yolo')
AUR_HELPER = %w[paru yay].find { |cmd| system("command -v #{cmd} > /dev/null 2>&1") }

def open_url(url)
  system('xdg-open', url, out: File::NULL, err: File::NULL) == true
end

def strip_ansi(text)
  text.gsub(/\e\[[0-9;]*m/, '')
end

def ask_tty(prompt)
  tty = File.open('/dev/tty', 'r+')
  tty.print prompt
  tty.gets&.strip&.downcase
ensure
  tty&.close
end

def prompt_read_news(prompt = 'Read the news? [y/N/b=open in browser] ', require_browser: false)
  answer = ask_tty(prompt)
  decline_or_yolo('No input received.') if answer.nil?
  valid = require_browser ? %w[y yes] : %w[y yes b browser]
  decline_or_yolo unless valid.include?(answer)
  opens_browser = require_browser ? %w[y yes].include?(answer) : %w[b browser].include?(answer)
  if opens_browser && !open_url(NEWS_URL)
    warn 'Failed to open browser.'
    exit 1
  end
  puts opens_browser ? 'Arch News opened.' : 'All caught up!'
end

def prompt_manual_check
  prompt_read_news("Open #{NEWS_URL} to check manually? [y/N] ", require_browser: true)
end

def decline_or_yolo(preamble = nil)
  warn preamble if preamble
  if YOLO
    warn "\nYOLO! Skipping the news, what's the worst that could happen? (Famous last words) 🤞"
    exit 0
  end
  warn "\nNews not read. Till you can find the time..."
  ask_tty('Press Enter to close this window... ') if ENV['TMUX']
  exit 1
end

def fetch_news
  stdout, stderr, status = Open3.capture3(AUR_HELPER, '-Pw', '--color', 'always')
  [stdout.strip, stderr.strip, status]
end

def display_news(stdout)
  count = strip_ansi(stdout).scan(/^\d{4}-\d{2}-\d{2} /).length
  puts
  puts "Arch News Since Last Update (#{count} item#{count == 1 ? '' : 's'}):"
  puts
  print stdout
  puts
end

def main
  unless AUR_HELPER
    warn "Neither paru nor yay found. Unable to check the news automatically.\n"
    prompt_manual_check
    return
  end

  stdout, stderr, status = fetch_news

  if stdout.empty?
    if status.success? || stderr.match?(/no new news/i)
      puts 'Arch News: 0 items since last update (no news is good news)'
      return
    end
    warn "Could not fetch Arch News: #{stderr.empty? ? 'unknown error' : stderr}"
    puts
    prompt_manual_check
    return
  end

  display_news(stdout)
  prompt_read_news
end

main
