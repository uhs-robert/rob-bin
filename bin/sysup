#!/usr/bin/env ruby
# frozen_string_literal: true

require 'fileutils'
require_relative '../lib/tee_io'
require_relative '../lib/notification'
require_relative '../lib/shell'
require_relative '../lib/user_interface'
require_relative '../lib/options_parser'
require_relative '../lib/dnf_manager'
require_relative '../lib/flatpak_manager'
require_relative '../lib/terminal_style'

# Orchestrates the system update process
class SystemUpdater
  include UserInterface
  include OptionsParser

  attr_reader :options, :dnf_flags

  def initialize
    @options = parse_options
    @dnf_flags = @options[:auto_confirm] ? ['-y'] : []
    @progress_id = nil
    @log_file = setup_logging
    @dnf = DnfManager.new(self)
    @flatpak = FlatpakManager.new(self)
  end

  def run
    setup_traps
    check_dependencies
    Style.print_title '󰌢 SYSTEM UPDATE'
    notify('Running system update...', icon: 'mintupdate-checking')
    run_sequence
    finish_update
  end

  def step(title, notification_body = nil, icon: 'mintupdate-installing', log: true)
    Style.print_header title
    notify(notification_body, icon: icon) if notification_body
    $stdout.logging = log if $stdout.respond_to?(:logging=)
    yield if block_given?
  ensure
    $stdout.logging = true if $stdout.respond_to?(:logging=)
  end

  def log_message(msg)
    $stdout.log_only(msg) if $stdout.respond_to?(:log_only)
  end

  def notify(body, icon: 'mintupdate-installing', actions: {}, timeout: 0)
    @progress_id = Notification.show(
      title: 'System Update', body: body, replace_id: @progress_id,
      icon: icon, silent: @options[:silent_run], actions: actions, timeout: timeout
    )
  end

  private

  def run_sequence
    @dnf.refresh_cache
    @dnf.update
    @dnf.security
    @flatpak.update
    @dnf.post_process
    cleanup_all
  end

  def cleanup_all
    step(' Cleaning Up', 'Cleaning packages and configs...')
    @dnf.autoremove
    @flatpak.cleanup
    clean_leftover_rpm_configs
  end

  def clean_leftover_rpm_configs
    Style.print_subheader 'RPM Configuration Files'
    rpm_files = Shell.with_spinner('Checking RPM configs...') { Shell.capture('sudo', 'rpmconf', '-a') }
    puts rpm_files.strip.empty? ? '  Nothing to do.' : rpm_files
  end

  def check_dependencies
    missing = %w[rpmconf flatpak remove-retired-packages].reject { |cmd| system("command -v #{cmd} > /dev/null 2>&1") }
    return if missing.empty?

    puts "Installing missing dependencies: #{missing.join(' ')}"
    system('sudo', 'dnf', 'install', *@dnf_flags, *missing)
  end

  def setup_logging
    log_dir = File.join(Dir.home, '.log')
    FileUtils.mkdir_p(log_dir)
    path = File.join(log_dir, "system_update_#{Time.now.strftime('%F_%H-%M-%S')}.log")
    @log_fh = File.open(path, 'w')
    $stdout = TeeIO.new($stdout, @log_fh)
    $stderr = TeeIO.new($stderr, @log_fh)
    path
  end

  def setup_traps
    at_exit { cleanup }
    trap('INT') { interrupt }
    trap('TERM') { interrupt }
  end

  def interrupt
    puts "\n#{Style::ERROR}Update interrupted!#{Style::NC}"
    exit 1
  end

  def any_updates? = (@dnf.count + @flatpak.count).positive?

  def cleanup
    $stdout = STDOUT
    $stderr = STDERR
    @log_fh&.close

    if any_updates?
      total = @dnf.count + @flatpak.count
      puts "#{Style::OK}#{total} updated. Log: file://#{@log_file}#{Style::NC}"
      puts "#{Style::WARNING}Reboot required.#{Style::NC}" if @dnf.needs_reboot
    else
      FileUtils.rm_f(@log_file)
    end
  end

  def finish_update
    puts
    Style.print_title(' DONE', color: Style::OK)
    $stdout.flush
    prompt_user(@dnf.needs_reboot, @log_file, @options)
  end
end

# ── Execution ─────────────────────────────────────────────────────────────────

SystemUpdater.new.run
